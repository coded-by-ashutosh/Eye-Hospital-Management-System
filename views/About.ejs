<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('CDN/bootstrap.ejs') %>
</head>

<body>

    <%- include('Header/Home_Header.ejs') %>

        <!-- HERO -->
        <section class="eyra-about-hero mt-5">
            <div class="container">
                <div class="row align-items-center py-1">
                    <div class="col-lg-7">
                        <h1 class="eyra-hero-title mb-4">Dedicated to Protecting and Restoring Your Vision</h1>
                        <p class="eyra-hero-text">
                            At EYRA Eye Care Center, we believe that healthy vision is essential for living a confident
                            and independent life. Our clinic was founded with a clear mission — to provide reliable,
                            ethical, and patient-focused eye care services using modern diagnostic tools and
                            evidence-based treatments.
                        </p>
                        <p class="eyra-hero-text">
                            Whether you are visiting us for a regular check-up or a specialized consultation, you can
                            trust EYRA to deliver clarity, comfort, and care at every step of your journey.
                        </p>
                    </div>
                    <div class="col-lg-5 text-center">
                        <img src="/public/images/about-hero.jpg" class="eyra-about-hero-img" alt="Eye Care">
                    </div>
                </div>
            </div>
        </section>



        <!-- STATS -->
        <section class="eyra-about-stats mt-5">
            <div class="container">
                <div class="row g-4 text-center">

                    <div class="col-md-3">
                        <div class="eyra-stat-card">
                            <img src="../public/icons/eye.png" alt="" height="50" width="50">
                            <h3 class="mt-3">50k+</h3>
                            <p class="text-muted">Successful Treatments</p>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="eyra-stat-card">
                            <img src="../public/icons/doctor.png" alt="" height="50" width="50">
                            <h3 class="mt-3">20+</h3>
                            <p class="text-muted">Specialists</p>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="eyra-stat-card">
                            <img src="../public/icons/hospital.png" alt="" height="50" width="50">
                            <h3 class="mt-3">10+</h3>
                            <p class="text-muted">Years Experience</p>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="eyra-stat-card">
                            <img src="../public/icons/trust.png" alt="" height="50" width="50">
                            <h3 class="mt-3">100%</h3>
                            <p class="text-muted">Patient Trust</p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- STORY -->
        <section class="eyra-about-section mt-5 mb-5">
            <div class="container">
                <div class="row g-5 align-items-center">

                    <div class="col-lg-6">
                        <img src="/public/images/about-story.jpg" class="eyra-about-img" alt="Our Story">
                    </div>

                    <div class="col-lg-6">
                        <h2 class="eyra-about-heading">Our Journey</h2>
                        <p class="eyra-about-text">
                            EYRA Eye Care Center was established with a simple yet powerful idea — every individual
                            deserves access to quality eye care, delivered with honesty and compassion. What began as a
                            vision to serve patients with integrity has grown into a trusted eye care destination for
                            individuals and families.
                        </p>
                        <p class="eyra-about-text">
                            We strongly believe that effective eye care goes beyond prescriptions and procedures. It
                            involves educating patients, addressing concerns with clarity, and building long-term
                            relationships based on trust. This philosophy has guided us in treating thousands of
                            patients while maintaining the highest ethical and professional standards.
                        </p>
                    </div>

                </div>
            </div>
        </section>


        <!-- VALUES -->
        <section class="eyra-about-values py-5">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="eyra-about-values-title">Our Core Values</h2>
                    <p class="eyra-about-values-subtitle">What defines our care</p>
                </div>

                <div class="row g-4">

                    <div class="col-md-4">
                        <div class="eyra-value-card">
                            <i class="bi bi-heart-pulse"></i>
                            <h5>Compassion</h5>
                            <p>We treat patients with empathy and respect.</p>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="eyra-value-card">
                            <i class="bi bi-clipboard-data"></i>
                            <h5>Precision</h5>
                            <p>Accurate diagnosis using advanced technology.</p>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="eyra-value-card">
                            <i class="bi bi-award"></i>
                            <h5>Integrity</h5>
                            <p>Transparent guidance and ethical practice.</p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

