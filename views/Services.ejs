<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('CDN/bootstrap.ejs') %>
    <link rel="stylesheet" href="/public/css/services.css">
</head>

<body>

  <%- include('Header/Home_Header.ejs') %>

    <!-- SERVICES HERO -->
    <section class="eyra-services-hero py-5 mt-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-9 text-center">
            <h1 class="eyra-services-title mb-3">
              Our Eye Care Services
            </h1>
            <p class="eyra-services-subtitle mb-0">
              Comprehensive eye treatments delivered with precision, care, and compassion.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES GRID -->
    <section class="eyra-services-section py-5 mt-5">
      <div class="container">

        <div class="row g-4">

          <!-- Service Card -->
          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-eye"></i>
              </div>
              <h5 class="mb-2">General Eye Checkup</h5>
              <p class="mb-0">
                Complete vision examination for early detection and prevention of eye disorders.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-capsule"></i>
              </div>
              <h5 class="mb-2">Cataract Surgery</h5>
              <p class="mb-0">
                Advanced and safe cataract procedures using modern surgical technology.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-diagram-3"></i>
              </div>
              <h5 class="mb-2">Retina & Diagnostics</h5>
              <p class="mb-0">
                Accurate retina evaluation and diagnostics for complex eye conditions.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-person-heart"></i>
              </div>
              <h5 class="mb-2">Pediatric Eye Care</h5>
              <p class="mb-0">
                Gentle and specialized eye care services for children of all ages.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-shield-check"></i>
              </div>
              <h5 class="mb-2">Glaucoma Treatment</h5>
              <p class="mb-0">
                Early detection, monitoring, and treatment to protect long-term vision.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-lightning-charge"></i>
              </div>
              <h5 class="mb-2">LASIK & Refractive Surgery</h5>
              <p class="mb-0">
                Modern laser treatments for vision correction with precision and safety.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-hospital"></i>
              </div>
              <h5 class="mb-2">Emergency Eye Care</h5>
              <p class="mb-0">
                Immediate attention for eye injuries and urgent vision-related issues.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-heart"></i>
              </div>
              <h5 class="mb-2">Eye Donation Guidance</h5>
              <p class="mb-0">
                Compassionate support and guidance for eye donation awareness and process.
              </p>
            </div>
          </div>

          <div class="col-lg-4 col-md-6">
            <div class="eyra-service-card p-4 h-100">
              <div class="service-icon mb-3">
                <i class="bi bi-eyeglasses"></i>
              </div>
              <h5 class="mb-2">Optical & Vision Correction</h5>
              <p class="mb-0">
                Personalized vision solutions including spectacles, lenses, and corrective guidance.
              </p>
            </div>
          </div>


        </div>

      </div>
    </section>

    <!-- EYRA CARE APPROACH SECTION -->
    <section class="eyra-care-section py-5">
      <div class="container">
        <div class="row align-items-center g-5">

          <!-- IMAGE SIDE -->
          <div class="col-lg-6">
            <div class="eyra-care-img-wrapper">
              <img src="/public/images/eye-care-process.jpg" alt="Patient First Eye Care">
            </div>
          </div>

          <!-- CONTENT SIDE -->
          <div class="col-lg-6">
            <h2 class="eyra-care-title">Patient-First Eye Care Approach</h2>

            <p class="eyra-care-text">
              At EYRA, every treatment begins with listening. We believe that
              understanding a patient’s concern is just as important as diagnosing
              the condition.
            </p>

            <p class="eyra-care-text">
              Our care process combines advanced diagnostic technology with
              compassionate medical expertise to ensure accuracy, comfort, and
              clarity at every stage of treatment.
            </p>

            <p class="eyra-care-text">
              From routine eye examinations to complex procedures, our focus remains
              on safety, transparency, and long-term visual wellness.
            </p>

            <!-- Highlight Points -->
            <div class="eyra-care-points">
              <p><i class="bi bi-check-circle"></i> Personalized consultations</p>
              <p><i class="bi bi-check-circle"></i> Modern diagnostic equipment</p>
              <p><i class="bi bi-check-circle"></i> Comfortable & hygienic environment</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- EYRA DOCTORS SECTION -->
    <section class="eyra-doctors-section py-5">
      <div class="container">

        <!-- SECTION HEADER -->
        <div class="text-center mb-5">
          <h2 class="eyra-doctors-title">Meet Our Eye Specialists</h2>
          <p class="eyra-doctors-subtitle">
            Experienced ophthalmologists committed to your vision and care
          </p>
        </div>

        <div class="row g-4 justify-content-center">

          <!-- Doctor Card -->
          <div class="col-lg-3 col-md-6">
            <div class="eyra-doctor-card text-center">
              <div class="eyra-doctor-img">
                <img src="/public/Doctors_Photo/doctor1.jpg" alt="Dr. A Sharma">
              </div>
              <h5 class="mt-3">Dr. A. Sharma</h5>
              <span class="eyra-doctor-speciality">Senior Ophthalmologist</span>
              <p class="eyra-doctor-exp">
                <i class="bi bi-award"></i> 15+ Years Experience
              </p>
            </div>
          </div>

          <!-- Doctor Card -->
          <div class="col-lg-3 col-md-6">
            <div class="eyra-doctor-card text-center">
              <div class="eyra-doctor-img">
                <img src="/public/Doctors_Photo/doctor2.jpg" alt="Dr. R Mehta">
              </div>
              <h5 class="mt-3">Dr. R. Mehta</h5>
              <span class="eyra-doctor-speciality">Cataract Specialist</span>
              <p class="eyra-doctor-exp">
                <i class="bi bi-award"></i> 12+ Years Experience
              </p>
            </div>
          </div>

          <!-- Doctor Card -->
          <div class="col-lg-3 col-md-6">
            <div class="eyra-doctor-card text-center">
              <div class="eyra-doctor-img">
                <img src="/public/Doctors_Photo/doctor3.jpg" alt="Dr. S Verma">
              </div>
              <h5 class="mt-3">Dr. S. Verma</h5>
              <span class="eyra-doctor-speciality">Retina & Diagnostics</span>
              <p class="eyra-doctor-exp">
                <i class="bi bi-award"></i> 10+ Years Experience
              </p>
            </div>
          </div>

          <!-- Doctor Card -->
          <div class="col-lg-3 col-md-6">
            <div class="eyra-doctor-card text-center">
              <div class="eyra-doctor-img">
                <img src="/public/Doctors_Photo/doctor4.jpg" alt="Dr. N Patel">
              </div>
              <h5 class="mt-3">Dr. N. Patel</h5>
              <span class="eyra-doctor-speciality">Pediatric Eye Care</span>
              <p class="eyra-doctor-exp">
                <i class="bi bi-award"></i> 8+ Years Experience
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- WHY TRUST EYRA -->
    <section class="eyra-services-trust mt-5">
      <div class="container">
        <div class="row text-center g-4">

          <div class="col-md-4">
            <div class="eyra-trust-card">
              <i class="bi bi-person-check mb-2"></i>
              <h5 class="mb-1">Experienced Specialists</h5>
              <p class="mb-0">Years of expertise in advanced ophthalmology.</p>
            </div>
          </div>

          <div class="col-md-4">
            <div class="eyra-trust-card">
              <i class="bi bi-gear-wide-connected mb-2"></i>
              <h5 class="mb-1">Modern Technology</h5>
              <p class="mb-0">Latest diagnostic and surgical equipment.</p>
            </div>
          </div>

          <div class="col-md-4">
            <div class="eyra-trust-card">
              <i class="bi bi-emoji-smile mb-2"></i>
              <h5 class="mb-1">Patient-First Care</h5>
              <p class="mb-0">Comfort, safety, and trust at every step.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <%- include('Appointment_Form/Form.ejs') %>
    <%- include('chat/chat.ejs') %>
    <%- include('Footer/Home_Footer.ejs') %>
    <%- include('CDN/javascript.ejs') %>

</body>

</html>