<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../CDN/bootstrap.ejs') %>
</head>

<body>
    <div class="d-flex">
        <%- include('../Header/Admin_Header.ejs') %>

            <div class="flex-grow-1 bg-light px-3 py-4">

                <div class="container-fluid">
                    <h1 class="publish-notifications-heading fw-bold mb-1">
                        Notifications
                    </h1>
                    <p class="text-muted mb-4">
                        Create and send announcements to users
                    </p>

                </div>



                <div class="container mt-2 login_div_margin_bottom">
                    <div class="row mt-5">
                        <div class="col-md-4 offset-md-4 mt-3">

                            <!-- OPTIONAL TOP ICON / IMAGE -->
                            <!-- <img src="/public/images/settings.png"
           class="img-fluid mx-auto d-block eyra-login-img"
           alt="Settings"> -->

                            <!-- CARD -->
                            <div class="card eyra-publish-notifications-card">

                                <!-- HEADER -->
                                <div class="card-header text-center eyra-publish-notifications-header mt-3">
                                    <h3>
                                        <i class="bi bi-megaphone-fill me-2"></i>
                                        New Notification
                                    </h3>
                                    <p class="eyra-publish-notifications-subtext">
                                        Send important updates to all users
                                    </p>

                                </div>


                                <!-- BODY -->
                                <div class="card-body eyra-publish-notifications-card-body">

                                    <form action="/push_notifications" method="POST">

                                        <div class="form-group mb-3">
                                            <label for="title">Notification Title</label>
                                            <input type="text" class="form-control" id="title" name="title"
                                                placeholder="Enter notification title" required>

                                            <label for="message" class="mt-3">Notification Message</label>
                                            <textarea class="form-control" id="message" name="message" rows="4"
                                                placeholder="Type your message here..." required></textarea>
                                        </div>

                                        <button type="submit" class="btn btn-primary mt-2 w-100 eyra-publish-notifications-btn">Send Notification</button>

                                    </form>


                                    <!-- INFO -->
                                    <div class="text-center mt-3">
                                        <small class="text-muted">Notifications will be sent instantly to all active
                                            users</small>
                                    </div>


                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                <% if(locals.msg) {%>

                    <div class="text-center text-success mt-5 pb-3 fw-semibold">
                        <h5>
                            <%=msg%>
                        </h5>
                    </div>

                    <% } %>

            </div>
    </div>

    <%- include('../Footer/Dashboard_Footer.ejs') %>
        <%- include('../CDN/javascript.ejs') %>

</body>

</html>