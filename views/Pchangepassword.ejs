<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('CDN/bootstrap.ejs') %>
</head>

<body>
  <div class="d-flex">
    <%- include('Header/Patient_Header.ejs') %>

      <div class="flex-grow-1 bg-light px-3 py-4">

        <div class="container-fluid">
          <h1 class="settings-heading fw-bold mb-2">Account Settings</h1>
          <p class="text-muted mb-5">
            Manage your personal information, security, and preferences
          </p>
        </div>




        <div class="container mt-2 login_div_margin_bottom">
          <div class="row mt-5">
            <div class="col-md-4 offset-md-4 mt-3">

              <!-- OPTIONAL TOP ICON / IMAGE -->
              <!-- <img src="/public/images/settings.png"
           class="img-fluid mx-auto d-block eyra-login-img"
           alt="Settings"> -->

              <!-- CARD -->
              <div class="card eyra-settings-card">

                <!-- HEADER -->
                <div class="card-header text-center eyra-settings-header mt-3">
                  <h3>
                    <i class="bi bi-shield-lock-fill me-2"></i>
                    Change Password
                  </h3>
                  <p class="eyra-settings-subtext">
                    Update your account password securely
                  </p>
                </div>

                <!-- BODY -->
                <div class="card-body eyra-settings-card-body">

                  <form action="/Patient_settings" method="POST">

                    <div class="form-group mb-3">
                      <label for="old">Current Password</label>
                      <input type="password" class="form-control" id="old" name="oldpassword" required>

                      <label for="newpassword" class="mt-3">New Password</label>
                      <input type="password" class="form-control" id="newpassword" name="newpassword" required>

                      <label for="confpassword" class="mt-3">Confirm New Password</label>
                      <input type="password" class="form-control" id="confpassword" name="confpassword" required>
                    </div>

                    <button type="submit" class="btn btn-primary mt-2 w-100 eyra-settings-btn">
                      Update Password
                    </button>

                  </form>

                  <!-- INFO -->
                  <div class="text-center mt-3">
                    <small class="text-muted">
                      Make sure your password is strong and unique
                    </small>
                  </div>

                </div>

              </div>
            </div>
          </div>
        </div>

        <% if(locals.msg) {%>

          <div class="text-center text-success mt-5 pb-3 fw-semibold">
            <h5>
              <%=msg%>
            </h5>
          </div>

          <% } %>

      </div>
  </div>

  <%- include('Footer/Dashboard_Footer.ejs') %>
    <%- include('CDN/javascript.ejs') %>

</body>

</html>